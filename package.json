{
  "name": "@gridmason/dashboard",
  "version": "0.0.0",
  "private": true,
  "description": "Gridmason Dashboard — permanent, product-neutral app over @gridmason/core + a Gridmason Registry. OSS showcase + widget-author dev target.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:static-demo": "tsc --noEmit && GRIDMASON_STATIC_DEMO=1 vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --port 4173",
    "preview:static-demo": "vite preview --port 4273",
    "test": "vitest run",
    "api:dev": "tsx watch server/main.ts",
    "api:start": "tsx server/main.ts",
    "api:typecheck": "tsc -p tsconfig.server.json",
    "api:test": "vitest run server",
    "e2e": "playwright test",
    "e2e:static-demo": "npm run build:static-demo && playwright test --config playwright.static-demo.config.ts",
    "e2e:real-cli": "playwright test --config playwright.real-cli.config.ts",
    "e2e:install": "playwright install --with-deps chromium",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "@gridmason/core": "0.5.3",
    "@gridmason/protocol": "0.4.0",
    "@gridmason/sdk": "0.4.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "wouter": "3.10.0"
  },
  "devDependencies": {
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@gridmason/protocol": "0.4.0"
  }
}
